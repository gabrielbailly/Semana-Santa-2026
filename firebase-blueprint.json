{
  "entities": {
    "Score": {
      "title": "Score",
      "description": "A player's quiz score",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Player name"
        },
        "score": {
          "type": "number",
          "description": "Quiz score"
        },
        "difficulty": {
          "type": "string",
          "description": "Difficulty level"
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 date string"
        }
      },
      "required": ["name", "score", "difficulty", "date"]
    }
  },
  "firestore": {
    "scores": {
      "schema": "Score",
      "description": "Collection of quiz scores"
    }
  }
}
